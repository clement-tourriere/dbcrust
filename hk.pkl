amends "package://github.com/jdx/hk/releases/download/v1.39.0/hk@1.39.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.39.0/hk@1.39.0#/Builtins.pkl"

local linters = new Mapping<String, Step> {
    ["trailing-whitespace"] = Builtins.trailing_whitespace
    ["newlines"] = Builtins.newlines
    ["check-merge-conflict"] = Builtins.check_merge_conflict
    ["cargo-fmt"] {
        glob = "**/*.rs"
        exclude = "python/**"
        check = "rustfmt --check"
        fix = "rustfmt"
    }
    ["cargo-clippy"] {
        glob = "**/*.rs"
        exclude = List("python/**", "tests/**")
        // Same flags as CI (ci.yml); structural allows live in Cargo.toml [lints.clippy]
        check = "cargo clippy --all-targets -- -D warnings"
    }
    ["ruff"] {
        glob = "python/**/*.py"
        // Same rule selection as CI (ci.yml "ruff (errors only)")
        check = "ruff check python/dbcrust --select E9,F821,F811"
        fix = "ruff check python/dbcrust --select E9,F821,F811 --fix"
    }
    ["ty"] {
        glob = "python/**/*.py"
        check = "ty check python/dbcrust"
    }
}

hooks {
    ["pre-commit"] {
        fix = true
        stash = "git"
        steps {
            ...linters
        }
    }
    ["commit-msg"] {
        steps {
            ["check-conventional-commit"] = Builtins.check_conventional_commit
        }
    }
    ["check"] {
        steps {
            ...linters
        }
    }
    ["fix"] {
        fix = true
        steps {
            ...linters
        }
    }
}
